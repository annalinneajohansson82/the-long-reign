# Hermes machine user identity for automated git/GitHub operations
# Copy this to .env in the project root and fill in your values.
# .env is gitignored — do NOT commit it.

HERMES_MACHINE_USER_NAME=<your-machine-user-name>
HERMES_MACHINE_USER_EMAIL=<your-machine-user-email>
HERMES_REPO_OWNER=<your-github-username>
HERMES_GITHUB_TOKEN=<your-token-here>